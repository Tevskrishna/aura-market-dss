# AURA-Market / RealEstateIQ — environment template
# Copy to Streamlit Cloud → Secrets, or local .env (not committed).

# Data mode: hybrid (default) | local | live
AURA_DATA_ADAPTER_MODE=hybrid
# Catalog backend: csv (default) | sqlite
AURA_DATA_BACKEND=csv

# Live competition overlays (JSON arrays matching seed schemas).
# Local demo path (repo-relative) works without the internet:
AURA_LIVE_RERA_URL=data/live_samples/rera.json
# AURA_LIVE_UPCOMING_URL=https://partner.example/api/upcoming.json
# AURA_LIVE_UC_URL=
# AURA_LIVE_LAND_URL=
AURA_LIVE_TIMEOUT_SEC=8

# Auth — override demo passwords; optional SHA-256 with salt
AURA_ADMIN_PASSWORD=admin123
AURA_DEMO_PASSWORD=demo123
# AURA_AUTH_SALT=your-long-random-salt
# AURA_ADMIN_PASSWORD_HASH=
# AURA_DEMO_PASSWORD_HASH=
